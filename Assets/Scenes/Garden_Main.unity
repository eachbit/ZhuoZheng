  objectiveChooseFlowAfterWestRejected: "\u897F\u6E20\u5C3D\u5934\u53EA\u5269\u7A7A\u54CD\uFF0C\u518D\u8BD5\u5357\u6E20\u6216\u4E2D\u6C60\u3002"
  objectiveChooseFlowAfterSouthRejected: "\u5357\u6E20\u867D\u6709\u52A8\u9759\uFF0C\u5374\u6CA1\u6709\u5524\u9192\u6C34\u8109\uFF0C\u518D\u8BD5\u897F\u6E20\u6216\u4E2D\u6C60\u3002"
  objectiveChooseFlowAfterAllRejected: "\u897F\u6E20\u3001\u5357\u6E20\u90FD\u4E0D\u901A\uFF0C\u771F\u6B63\u7684\u6D3B\u6C34\u5E94\u56DE\u5230\u4E2D\u6C60\u3002"
  objectiveCollectPage: "\u5728\u77F3\u9699\u95F4\u5BFB\u5F97\u300A\u957F\u7269\u5FD7\u300B\u6B8B\u9875\u3002"
  objectiveCompleted: "\u7B2C\u4E00\u7AE0\u5DF2\u5B8C\u6210\uFF0C\u7EE7\u7EED\u524D\u884C\u3002"
  flowHintWestRejected: "\u897F\u6E20\u5C3D\u5934\u4F20\u6765\u7A7A\u54CD\uFF0C\u50CF\u662F\u65AD\u5728\u6B7B\u8DEF\u91CC\u3002"
  flowHintSouthRejected: "\u5357\u6E20\u6709\u6C34\u58F0\u5374\u6CA1\u6709\u805A\u5230\u4E2D\u6C60\uFF0C\u8FD9\u6761\u8DEF\u4E0D\u5BF9\u3002"
  flowHintAllRejected: "\u4E24\u6761\u65C1\u8DEF\u90FD\u4E0D\u901A\uFF0C\u771F\u6B63\u7684\u6D3B\u6C34\u5E94\u56DE\u5230\u4E2D\u6C60\u3002"
  flowHintCorrect: "\u4E2D\u6C60\u6DF1\u5904\u4F20\u6765\u56DE\u54CD\uFF0C\u6C34\u8109\u88AB\u63A5\u901A\u4E86\u3002"
